library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity ctrl_tec is
  generic(
    TICS_2s : natural := 400  -- en testbench lo escalas a 10
  );
  port(
    clk  : in std_logic;
    nRst : in std_logic;
    tic  : in std_logic; -- Pulso de 5 ms

    col0 : in std_logic;
    col1 : in std_logic;
    col2 : in std_logic;
    col3 : in std_logic;

    fil0 : buffer std_logic;
    fil1 : buffer std_logic;
    fil2 : buffer std_logic;
    fil3 : buffer std_logic;

    tecla         : buffer std_logic_vector(3 downto 0);
    tecla_pulsada : buffer std_logic;              -- pulso 1 clk para corta
    pulso_largo   : buffer std_logic               -- pulso 1 clk para larga
  );
end entity;

architecture rtl of ctrl_tec is
  type estado_t is (STOP, ESCANEO, PULSADO);
  signal estado : estado_t;

  signal fila_sel        : std_logic_vector(1 downto 0);
  signal tecla_reg       : std_logic_vector(3 downto 0);
  signal tp_reg          : std_logic;
  signal reg_pl          : std_logic;
  signal cnt_tic         : natural range 0 to TICS_2s + 1;

  signal pulsacion       : std_logic;
  signal pulsacion_r     : std_logic;
  signal pulsacion_fall  : std_logic;  -- 1->0 = se suelta tecla
begin

  -- Registro para detectar flanco de soltado
  process(clk, nRst)
  begin
    if nRst = '0' then
      pulsacion_r <= '0';
    elsif clk'event and clk = '1' then
      pulsacion_r <= pulsacion;
    end if;
  end process;

  -- '1' un ciclo cuando se suelta la tecla
  pulsacion_fall <= pulsacion_r and (not pulsacion);

  -- Algoritmo principal
  process(clk, nRst)
  begin
    if nRst = '0' then
      estado    <= STOP;
      fila_sel  <= "00";
      tecla_reg <= (others => '0');
      tp_reg    <= '0';
      reg_pl    <= '0';
      cnt_tic   <= 0;

     elsif clk'event and clk = '1' then
      -- salidas tipo pulso: por defecto a 0
      tp_reg <= '0';
      reg_pl <= '0';

      case estado is
        when STOP =>
          estado   <= ESCANEO;
          fila_sel <= "00";
          cnt_tic  <= 0;

        when ESCANEO =>
          cnt_tic <= 0;

          if tic = '1' then
            if pulsacion = '1' then
              -- Decodifica tecla seg·n fila activa y columna baja
              case fila_sel is
                when "00" =>
                  if    col0 = '0' then tecla_reg <= x"1";
                  elsif col1 = '0' then tecla_reg <= x"2";
                  elsif col2 = '0' then tecla_reg <= x"3";
                  else                    tecla_reg <= x"F";
                  end if;

                when "01" =>
                  if    col0 = '0' then tecla_reg <= x"4";
                  elsif col1 = '0' then tecla_reg <= x"5";
                  elsif col2 = '0' then tecla_reg <= x"6";
                  else                    tecla_reg <= x"E";
                  end if;

                when "10" =>
                  if    col0 = '0' then tecla_reg <= x"7";
                  elsif col1 = '0' then tecla_reg <= x"8";
                  elsif col2 = '0' then tecla_reg <= x"9";
                  else                    tecla_reg <= x"D";
                  end if;

                when "11" =>
                  if    col0 = '0' then tecla_reg <= x"A";
                  elsif col1 = '0' then tecla_reg <= x"0";
                  elsif col2 = '0' then tecla_reg <= x"B";
                  else                    tecla_reg <= x"C";
                  end if;

                when others =>
                  null;
              end case;

              estado <= PULSADO;

            else
              -- siguiente fila
              case fila_sel is
                when "00" => fila_sel <= "01";
                when "01" => fila_sel <= "10";
                when "10" => fila_sel <= "11";
                when others => fila_sel <= "00";
              end case;
            end if;
          end if;

        when PULSADO =>
          if tic = '1' then
            -- Clasificar SOLO al soltar
            if pulsacion = '0' then
              if cnt_tic >= TICS_2s then
                reg_pl <= '1'; -- larga
              else
                tp_reg <= '1'; -- corta
              end if;

              estado   <= ESCANEO;
              cnt_tic  <= 0;

            else
              if cnt_tic < TICS_2s + 1 then
                cnt_tic <= cnt_tic + 1;
              end if;
            end if;
          end if;

      end case;
    end if;
  end process;

  tecla         <= tecla_reg;
  tecla_pulsada <= tp_reg;
  pulso_largo   <= reg_pl;

  -- Filas activas a '0' (una por vez)
  fil0 <= '0' when fila_sel = "00" else '1';
  fil1 <= '0' when fila_sel = "01" else '1';
  fil2 <= '0' when fila_sel = "10" else '1';
  fil3 <= '0' when fila_sel = "11" else '1';

  -- Hay pulsaci¾n si alguna columna estß baja
  pulsacion <= '1' when (col0 = '0' or col1 = '0' or col2 = '0' or col3 = '0')
               else '0';

end rtl;